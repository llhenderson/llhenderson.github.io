   "source": [
    "import numpy as np\n",
    "def rosenbrock(x,y):\n",
    "    return (1-x)**2 + 100*(y-x**2)**2\n",
    "# Gradient of the Rosenbrock function\n",
    "def grad_rosenbrock(w):\n",
    "    x= w[0]\n",
    "    y= w[1]\n",
    "    return np.array([-2*(1-x)-400*x*(y-x**2),200*(y-x**2)])\n"
   ]
  },
